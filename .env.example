# Copy to `.env` for local use, or set these as environment variables in Coolify.
# Generate fresh values for production — do NOT reuse the samples below.
#
#   GARAGE_RPC_SECRET   openssl rand -hex 32
#   GARAGE_ADMIN_TOKEN  openssl rand -base64 32
#   S3_ACCESS_KEY       "GK" + openssl rand -hex 12
#   S3_SECRET_KEY       openssl rand -hex 32

# Internal cluster + admin secrets (keep private)
GARAGE_RPC_SECRET=replace-with-openssl-rand-hex-32
GARAGE_ADMIN_TOKEN=replace-with-openssl-rand-base64-32

# S3 credentials your app uses to connect
S3_ACCESS_KEY=GKreplace-with-openssl-rand-hex-12
S3_SECRET_KEY=replace-with-openssl-rand-hex-32

# Bucket + node capacity
BUCKET_NAME=customer-data
CAPACITY=50G

# Login for the public admin web UI (garage-webui), format "username:bcrypt-hash".
# The compose file forwards this verbatim (pass-through), so use SINGLE "$" here
# and in Coolify's env UI — do NOT double them.
# Generate a hash:
#   htpasswd -nbBC 10 admin 'your-password' | cut -d: -f2
AUTH_USER_PASS=admin:$2y$10$REPLACE_WITH_YOUR_OWN_BCRYPT_HASH