# Coolify auto-generates SERVICE_PASSWORD_* vars. Set the values below in
# Coolify's Environment Variables UI. Passwords are injected via .env so
# they never appear in the compose file.

# --- Auto-generated by Coolify (SERVICE_PASSWORD_*) ---
SERVICE_PASSWORD_RPCSECRET=
SERVICE_PASSWORD_ADMINTOKEN=
SERVICE_PASSWORD_METRICSTOKEN=
SERVICE_PASSWORD_WEBUI=

# --- S3 credentials (set manually) ---
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Bucket config ---
BUCKET_NAME=customer-data
CAPACITY=50G

# --- Coolify resource UUID (injected automatically) ---
COOLIFY_RESOURCE_UUID=

# --- Domain routing (injected by Coolify when you assign domains) ---
SERVICE_URL_GARAGE=
SERVICE_FQDN_GARAGE=
SERVICE_URL_GARAGE_WEBUI=
SERVICE_FQDN_GARAGE_WEBUI=