# Environment variables for the Garage Application on Coolify.
# Set these in the Coolify Application -> Environment Variables UI.
# Garage's whole config is generated from these at container start
# (server-init.sh), so an admin can change anything here without touching files.
#
# REQUIRED are marked [req]. Everything else is optional: if you leave it unset,
# Garage's own default applies (shown in parentheses). Never commit real values.

# =============================================================================
# Secrets  [req] — read by Garage natively from the environment (never written
# to disk). Generate fresh production values:
#   openssl rand -hex 32      -> GARAGE_RPC_SECRET
#   openssl rand -base64 32   -> GARAGE_ADMIN_TOKEN, GARAGE_METRICS_TOKEN
# =============================================================================
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=

# =============================================================================
# S3 access key for your apps (imported into Garage on first boot)
#   GKxxxx access id:  echo "GK$(openssl rand -hex 12)"
#   secret key:        openssl rand -hex 32
# =============================================================================
S3_ACCESS_KEY=
S3_SECRET_KEY=

# =============================================================================
# Bucket + cluster layout
# =============================================================================
BUCKET_NAME=customer-data         # (also accepts S3_BUCKET)
CAPACITY=20G                       # node capacity for the layout (cap: 20G)
ZONE=dc1                           # layout zone name

# =============================================================================
# Public domains — HOST ONLY (no scheme, no port). A full URL is auto-normalized
# but host-only is clearest. These set Garage's vhost-style routing.
#   S3_DOMAIN=s3.example.com    -> bucket.s3.example.com  + path-style on s3.example.com
#   WEB_DOMAIN=media.example.com-> bucket.media.example.com static hosting
# (The https://host:port form belongs only in Coolify's Domains field.)
# =============================================================================
S3_DOMAIN=s3.example.com
WEB_DOMAIN=media.example.com

# =============================================================================
# S3 API
# =============================================================================
S3_REGION=Germany-1                # must match what your S3 clients use
# GARAGE_S3_API_BIND_ADDR=[::]:3900  (keep 3900 unless you also remap the port)

# =============================================================================
# Static website serving
# =============================================================================
# GARAGE_WEB_ENABLE=true           # set false to disable the [s3_web] endpoint
# GARAGE_WEB_BIND_ADDR=[::]:3902
# WEB_INDEX=index.html
# GARAGE_WEB_ADD_HOST_TO_METRICS=false

# =============================================================================
# Admin API + metrics
# =============================================================================
# GARAGE_ADMIN_BIND_ADDR=[::]:3903
# GARAGE_METRICS_REQUIRE_TOKEN=false   # require the bearer token on /metrics
# GARAGE_ADMIN_TRACE_SINK=             # OTLP endpoint for traces

# =============================================================================
# Storage engine & data layout
# =============================================================================
# GARAGE_DB_ENGINE=lmdb            # lmdb (default) | sqlite | fjall
# GARAGE_METADATA_DIR=/var/lib/garage/meta
# GARAGE_DATA_DIR=/var/lib/garage/data
# GARAGE_LMDB_MAP_SIZE=1G          # max LMDB map size (lmdb only)
# GARAGE_FJALL_BLOCK_CACHE_SIZE=   # fjall only

# =============================================================================
# Durability & maintenance
# =============================================================================
# GARAGE_METADATA_FSYNC=false      # fsync metadata writes (safer, slower)
# GARAGE_DATA_FSYNC=false          # fsync data block writes
# GARAGE_DISABLE_SCRUB=false       # disable periodic data scrubbing
# GARAGE_METADATA_AUTO_SNAPSHOT_INTERVAL=   # e.g. 6h  -> periodic meta snapshots
# GARAGE_METADATA_SNAPSHOTS_DIR=            # where snapshots are written
# GARAGE_USE_LOCAL_TZ=false

# =============================================================================
# Performance tuning
# =============================================================================
# GARAGE_COMPRESSION_LEVEL=1       # zstd level, or "none" to disable
# GARAGE_BLOCK_SIZE=1M             # data block size
# GARAGE_BLOCK_RAM_BUFFER_MAX=256M
# GARAGE_BLOCK_MAX_CONCURRENT_READS=16
# GARAGE_BLOCK_MAX_CONCURRENT_WRITES_PER_REQUEST=3
# GARAGE_CONSISTENCY_MODE=consistent   # consistent | degraded | dangerous

# =============================================================================
# Clustering / RPC (multi-node — single node needs none of these)
# =============================================================================
# GARAGE_RPC_BIND_ADDR=[::]:3901
# GARAGE_RPC_PUBLIC_ADDR=127.0.0.1:3901   # set to this node's reachable addr in a cluster
# GARAGE_RPC_BIND_OUTGOING=false
# GARAGE_RPC_PING_TIMEOUT_MSEC=
# GARAGE_RPC_TIMEOUT_MSEC=
# GARAGE_BOOTSTRAP_PEERS=id@host:3901,id@host2:3901   # comma-separated
# GARAGE_REPLICATION_FACTOR=1      # use 3 for a real multi-node cluster

# =============================================================================
# K2V API (key-value; off unless a bind addr is set)
# =============================================================================
# GARAGE_K2V_BIND_ADDR=[::]:3904

# =============================================================================
# Misc
# =============================================================================
# GARAGE_ALLOW_PUNYCODE=false

# =============================================================================
# Web UI (garage-webui) — defaults talk to Garage in-container; keep as-is
# unless you have a reason to change them.
# =============================================================================
AUTH_USER_PASS=                    # user:bcrypt-hash  (htpasswd -nbB admin 'pw')
# API_BASE_URL=http://127.0.0.1:3903     # admin API the UI calls (leave default!)
# S3 endpoint the Web UI uses for bucket browse (alias: S3_ENDPOINT_URL).
# MUST be in-container http://127.0.0.1:3900 — garage-webui and S3 API share one container.
# Do NOT use https://s3.blooming-brands.com here unless that domain is routed in Coolify;
# otherwise browse returns 503 Service Unavailable.
# S3_ENDPOINT=http://127.0.0.1:3900
# BASE_PATH=                              # serve UI under a sub-path, e.g. /garage
