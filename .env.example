# Environment variables for the Garage Application on Coolify.
# Set these in the Coolify Application -> Environment Variables UI.
# (As a Dockerfile Application — not a Service — use these plain names; Coolify
#  does NOT auto-generate SERVICE_PASSWORD_* here.) Never commit real values.

# --- Required secrets --------------------------------------------------------
# rpc_secret MUST be 32 bytes of hex:   openssl rand -hex 32
GARAGE_RPC_SECRET=
# admin + metrics API tokens:           openssl rand -base64 32
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=

# --- S3 credentials for your apps (set manually) -----------------------------
# Access key id convention:  GK + 24 hex chars ->  GK$(openssl rand -hex 12)
S3_ACCESS_KEY=
# Secret key:                openssl rand -hex 32
S3_SECRET_KEY=

# --- Bucket / capacity -------------------------------------------------------
BUCKET_NAME=customer-data
# Per the deployment cap, keep this at or below 20G.
CAPACITY=20G
ZONE=dc1

# --- Web UI login ------------------------------------------------------------
# Format:  username:bcrypt-hash   (htpasswd -bnBC 10 "" 'yourpassword' | tr -d ':\n' ... )
# Simplest: AUTH_USER_PASS=admin:$2y$10$....bcrypt....
AUTH_USER_PASS=

# --- Public domains (drive Garage's vhost-style S3 + static web routing) -----
# These set root_domain in garage.toml. Use the host parts only (no scheme).
S3_DOMAIN=s3.example.com
WEB_DOMAIN=web.example.com

# --- Optional ----------------------------------------------------------------
# S3_REGION=garage
