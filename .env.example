# ============================================================
# Garage Object Store — Environment Variables for Deployment
# ============================================================

# ---- Storage ----
# Directory where Garage stores metadata, ring state, etc.
# Persist this on a Docker volume so data survives restarts.
GARAGE_DATA_DIR=/var/lib/garage

# ---- Node Identity ----
# Unique node ID (auto-generated if empty). Set to same value across nodes
# if running a multi-node cluster.
# GARAGE_NODE_ID=                # optional — auto-generated
GARAGE_NODE_ADDR=0.0.0.0:3696  # Raft/internal gossip port

# ---- HTTP / API Listener ----
# S3-compatible API endpoint
GARAGE_SERVER_HTTP_LISTEN=0.0.0.0:80

# ---- Networking / Identity ----
# Fully qualified domain name that clients will use for presigned URLs.
# This MUST match the DNS name pointing at your server.
GARAGE_SERVER_FQDN=garage-os.blooming-brands.com

# Public base URL for generating presigned download/upload links.
# Set to GARAGE_SERVER_FQDN or explicit URL (with protocol).
GARAGE_SERVER_URL=https://garage-os.blooming-brands.com

# ---- API Key (admin) ----
# The admin API key is auto-generated on first boot and saved to:
#   $GARAGE_DATA_DIR/admin.apikey
# Load it after first start with:
#   GARAGE_API_KEY=$(cat /var/lib/garage/admin.apikey) garage tenant list
GARAGE_API_KEY=                # optional — auto-generated; set explicitly for cluster consistency

# ---- Logging ----
RUST_LOG=garage=info           # debug, info, warn, error
RUST_BACKTRACE=1               # include stack traces on panic
