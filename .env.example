# =============================================================================
# Garage S3-Compatible Storage — Coolify Dockerfile Deployment
# =============================================================================
# All values below are injected into the container at runtime by Coolify.
# The entrypoint script uses them to generate /etc/garage.toml on boot.
# =============================================================================

# ---------------------------------------------------------------------------
# 1. REQUIRED SECRETS
# ---------------------------------------------------------------------------
# 64-character hex string. Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=

# ---------------------------------------------------------------------------
# 2. CORE SERVER CONFIG (used to generate /etc/garage.toml)
# ---------------------------------------------------------------------------
GARAGE_RPC_BIND_ADDR=0.0.0.0:3900
GARAGE_METADATA_DIR=/var/lib/garage/meta
GARAGE_DATA_DIR=/var/lib/garage/data

GARAGE_S3_API_BIND_ADDR=0.0.0.0:3901
GARAGE_S3_REGION=us-east-1

GARAGE_WEB_BIND_ADDR=0.0.0.0:3902
GARAGE_WEB_ROOT_DOMAIN=.web.garage.local
GARAGE_WEB_INDEX=index.html

GARAGE_ADMIN_API_BIND_ADDR=0.0.0.0:3903

# ---------------------------------------------------------------------------
# 3. AUTO-INIT (optional — runs once on first boot)
# ---------------------------------------------------------------------------
# Leave blank to skip automatic bucket/key creation.
GARAGE_INIT_BUCKET=prod-bucket
GARAGE_INIT_KEY=prod-key

# ---------------------------------------------------------------------------
# 4. PUBLIC SERVER INFO (used in docs / client config)
# ---------------------------------------------------------------------------
GARAGE_SERVER_FQDN=garage.yourdomain.com
GARAGE_SERVER_URL=https://garage.yourdomain.com

# ---------------------------------------------------------------------------
# 5. SECURITY / TOKENS (documented — implement via reverse-proxy)
#    Garage admin & metrics endpoints have NO native token auth.
#    Lock them down with Nginx/Traefik basic-auth when exposing publicly.
# ---------------------------------------------------------------------------
GARAGE_ADMIN_TOKEN=change-me-admin-token
GARAGE_METRICS_TOKEN=change-me-metrics-token

# ---------------------------------------------------------------------------
# 6. COOLIFY SERVICE DISCOVERY (auto-populated by Coolify)
# ---------------------------------------------------------------------------
SERVICE_FQDN_GARAGE=
SERVICE_FQDN_WEBUI=
SERVICE_URL_WEBUI=
SERVICE_FQDN_S3=
SERVICE_URL_S3=

# ---------------------------------------------------------------------------
# 7. MISC
# ---------------------------------------------------------------------------
TZ=UTC
